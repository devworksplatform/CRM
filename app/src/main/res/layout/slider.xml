<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="4dp"
    android:paddingTop="6dp"
    android:paddingEnd="4dp"
    android:paddingBottom="6dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardview1"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false"
        app:cardCornerRadius="18dp"
        app:cardElevation="2dp"
        app:cardPreventCornerOverlap="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/imageview1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Banner"
                android:scaleType="centerCrop"
                android:src="@drawable/default_image" />

            <LinearLayout
                android:id="@+id/offerBannerTextContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/offer_banner_background"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="61dp"
                android:paddingTop="7dp"
                android:paddingEnd="10dp"
                android:paddingBottom="7dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:paddingEnd="9dp">

                    <TextView
                        android:id="@+id/offerBannerBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/offer_celebration_badge_background"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.08"
                        android:paddingStart="9dp"
                        android:paddingTop="3dp"
                        android:paddingEnd="9dp"
                        android:paddingBottom="3dp"
                        android:text="GROUP OFFER"
                        android:textColor="#4C1D95"
                        android:textSize="8sp" />

                    <TextView
                        android:id="@+id/offerBannerTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="2"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/offerBannerSubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="#FFF7ED"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/offerBannerAction"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="View products  →"
                        android:textColor="#FDE047"
                        android:textSize="11sp" />
                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:layout_width="92dp"
                    android:layout_height="match_parent"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/offerBannerImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="Offer product"
                        android:scaleType="centerCrop"
                        android:src="@drawable/default_image" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <FrameLayout
                android:id="@+id/offerConfettiOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/offerAnnouncementIcon"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="7dp"
                android:contentDescription="Offer announcement"
                android:src="@drawable/offer_megaphone_icon"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/offerCelebrationIcon"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_gravity="end|top"
                android:layout_marginTop="5dp"
                android:layout_marginEnd="5dp"
                android:contentDescription="Offer celebration"
                android:rotation="-90"
                android:src="@drawable/offer_party_popper_icon"
                android:visibility="gone" />
        </FrameLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>
